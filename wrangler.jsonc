/**
 * Wrangler configuration for the Code Reviewer Agent.
 * Secrets (API keys, tokens) are set via: npx wrangler secret put <KEY>
 * See README.md for the full setup guide.
 *
 * https://developers.cloudflare.com/workers/wrangler/configuration/
 */
{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "code-reviewer",
	"main": "src/index.ts",
	"compatibility_date": "2026-03-10",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"observability": {
		"enabled": true
	},
	/**
	 * Non-secret environment variables.
	 * Override at deploy time: npx wrangler deploy --var AI_PROVIDER:gemini
	 *
	 * AI_PROVIDER: "claude" (default) | "gemini"
	 */
	"vars": {
		"AI_PROVIDER": "claude",
		"ALLOWED_TARGET_BRANCHES": "dev",
		"CLIQ_BOT_NAME": "codereviewbot",
		"CLIQ_CHANNEL_ID": "prweb"
	},
	/**
	 * Queues
	 * Connects the fast webhook handler to the long-running LLM worker
	 */
	"queues": {
		"producers": [
			{
				"binding": "REVIEW_QUEUE",
				"queue": "code-reviewer-queue"
			}
		],
		"consumers": [
			{
				"queue": "code-reviewer-queue",
				"max_batch_size": 1,
				"max_concurrency": 2,
				"max_retries": 1
			}
		]
	},
	/**
	 * KV Namespace for storing usage metrics
	 */
	"kv_namespaces": [
		{
			"binding": "USAGE_METRICS",
			"id": "2825e1ef509f4069b316c5e96d1dd61b"
		}
	]
}